{{#> layout preview="Someone replied to your comment"}}
    {{> eyebrow text="New reply"}}
    <h1 style="margin:0 0 14px;font-size:23px;font-weight:700;line-height:1.28;letter-spacing:-0.02em;color:#0a0a0a;">Someone replied to you</h1>
    <p style="margin:0;color:#3f3f46;font-size:15px;line-height:1.65;">On <strong style="color:#0a0a0a;">{{eventTitle}}</strong>:</p>
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:16px 0 0;">
        <tr>
            <td style="padding:14px 18px;background:#f8f6f1;border-left:3px solid #ea580c;border-radius:0 10px 10px 0;color:#3f3f46;font-size:15px;line-height:1.6;font-style:italic;">{{preview}}</td>
        </tr>
    </table>
    {{> button label="Open the conversation" url=(concat webUrl "/events/" eventSlug)}}
{{/layout}}
