{{#> layout}}
<h1 style="margin:0 0 16px;font-size:20px;font-weight:700;letter-spacing:-0.02em;">{{title}}</h1>
{{{bodyHtml}}}
{{#if unsubscribeUrl}}
<hr style="border:none;border-top:1px solid #e4e4e7;margin:24px 0;">
<p style="color:#a1a1aa;font-size:12px;">You're receiving this because you opted in to updates from {{appName}}. <a href="{{unsubscribeUrl}}">Unsubscribe</a>.</p>
{{/if}}
{{/layout}}
