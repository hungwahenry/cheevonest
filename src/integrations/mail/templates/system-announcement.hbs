{{#> layout preview=title}}
    {{> eyebrow text="Announcement"}}
    <h1 style="margin:0 0 16px;font-size:23px;font-weight:700;line-height:1.28;letter-spacing:-0.02em;color:#0a0a0a;">{{title}}</h1>
    <div style="color:#3f3f46;font-size:15px;line-height:1.65;">{{{bodyHtml}}}</div>
    {{#if unsubscribeUrl}}
    {{> divider}}
    <p style="margin:0;color:#9a958c;font-size:12px;line-height:1.6;">You&rsquo;re receiving this because you opted in to updates from {{appName}}. <a href="{{unsubscribeUrl}}" style="color:#ea580c;">Unsubscribe</a>.</p>
    {{/if}}
{{/layout}}
