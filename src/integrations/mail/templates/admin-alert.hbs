{{#> layout preview=summary}}
    {{> eyebrow text="Admin alert"}}
    <h1 style="margin:0 0 14px;font-size:23px;font-weight:700;line-height:1.28;letter-spacing:-0.02em;color:#0a0a0a;">{{heading}}</h1>
    <p style="margin:0;color:#3f3f46;font-size:15px;line-height:1.65;">{{summary}}</p>
    {{#if rows.length}}
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:20px 0 0;background:#f8f6f1;border:1px solid #eceae3;border-radius:12px;">
        <tr>
            <td style="padding:4px 20px;">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                    {{#each rows}}
                    <tr>
                        <td style="padding:14px 0;{{#unless @last}}border-bottom:1px solid #eceae3;{{/unless}}color:#737373;font-size:14px;">{{this.label}}</td>
                        <td align="right" style="padding:14px 0;{{#unless @last}}border-bottom:1px solid #eceae3;{{/unless}}color:#0a0a0a;font-size:15px;font-weight:600;">{{this.value}}</td>
                    </tr>
                    {{/each}}
                </table>
            </td>
        </tr>
    </table>
    {{/if}}
{{/layout}}
