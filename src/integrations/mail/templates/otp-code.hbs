{{#> layout preview="Your cheevo verification code"}}
    <h1 style="margin:0 0 16px;font-size:22px;font-weight:600;line-height:1.3;color:#0a0a0a;letter-spacing:-0.01em;">Your verification code</h1>

    <p style="margin:0 0 8px;">Use this code to sign in to cheevo:</p>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:20px 0;background:#f4f4f5;border-radius:12px;">
        <tr>
            <td style="padding:20px 16px;text-align:center;font-family:'SF Mono',Menlo,Monaco,Consolas,monospace;font-size:28px;font-weight:600;letter-spacing:0.12em;color:#0a0a0a;">{{code}}</td>
        </tr>
    </table>

    <p style="margin:0;color:#737373;font-size:13px;">This code expires in {{ttlMinutes}} minutes. If you didn&rsquo;t request it, you can safely ignore this email.</p>
{{/layout}}
