{{#> layout preview=(concat "Your " appName " verification code")}}
    {{> eyebrow text="Verification"}}
    <h1 style="margin:0 0 14px;font-size:23px;font-weight:700;line-height:1.28;letter-spacing:-0.02em;color:#0a0a0a;">Your verification code</h1>
    <p style="margin:0;color:#3f3f46;font-size:15px;line-height:1.65;">Enter this code to sign in to {{appName}}. It expires in {{ttlMinutes}} minutes.</p>
    {{> code-box code=code}}
    <p style="margin:0;color:#8a857c;font-size:13px;line-height:1.6;">Didn&rsquo;t request this? You can safely ignore this email &mdash; your account stays secure.</p>
{{/layout}}
