{{#> layout}}
    {{> eyebrow text=organisationName}}
    <p style="margin:0 0 18px;color:#8a857c;font-size:13px;line-height:1.5;">Regarding {{eventTitle}}</p>
    <div style="color:#3f3f46;font-size:15px;line-height:1.65;">{{{bodyHtml}}}</div>
    {{> divider}}
    <p style="margin:0;color:#9a958c;font-size:12px;line-height:1.6;">You received this because you have tickets or an RSVP for {{eventTitle}}. <a href="{{unsubscribeUrl}}" style="color:#ea580c;">Unsubscribe</a> from {{organisationName}} emails.</p>
{{/layout}}
