{{#> layout preview="Confirm your email change"}}
    {{> eyebrow text="Email change"}}
    <h1 style="margin:0 0 14px;font-size:23px;font-weight:700;line-height:1.28;letter-spacing:-0.02em;color:#0a0a0a;">Confirm your new email</h1>
    <p style="margin:0;color:#3f3f46;font-size:15px;line-height:1.65;">You asked to change your {{appName}} email to <strong style="color:#0a0a0a;">{{newEmail}}</strong>. Enter this code to confirm the change.</p>
    {{> code-box code=code}}
    <p style="margin:0;color:#8a857c;font-size:13px;line-height:1.6;">This code expires in {{ttlMinutes}} minutes. If you didn&rsquo;t request this, secure your account right away.</p>
{{/layout}}
