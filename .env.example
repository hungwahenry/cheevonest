NODE_ENV=development
APP_NAME=cheevo
APP_KEY=dev-app-key-not-for-production
APP_URL=http://127.0.0.1:3000
WEB_URL=https://cheevo.events
PORT=3000
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/cheevo_nest
LOG_LEVEL=debug

STORAGE_DISK=local
STORAGE_DIR=storage/public
# Any S3-compatible store (AWS, R2, Spaces, MinIO). Existing files keep serving
# after a disk switch — refs are stored as "disk:path".
# S3_ENDPOINT=
# S3_REGION=auto
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=
# S3_FORCE_PATH_STYLE=true

MAIL_DRIVER=log
MAIL_FROM_ADDRESS=no-reply@cheevo.vip
MAIL_FROM_NAME=cheevo
# RESEND_API_KEY=
# Svix signing secret for the Resend webhook (bounces/complaints -> suppressions).
# RESEND_WEBHOOK_SECRET=

OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
# Comma-separated app-store review accounts that accept the fixed code below.
# OTP_REVIEW_EMAILS=
# OTP_REVIEW_CODE=

AUTH_TOKEN_TTL_MINUTES=43200

DICEBEAR_URL=https://api.dicebear.com/9.x
DICEBEAR_STYLE=thumbs
DICEBEAR_FORMAT=png

# Payments
PAYMENTS_DEFAULT_PROVIDER=paystack
# PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
# FLUTTERWAVE_SECRET_KEY=
# FLUTTERWAVE_SECRET_HASH=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
# HTTPS bridge for providers that refuse app-scheme callbacks.
# Defaults to APP_URL/payments/return when unset.
# PAYMENT_BRIDGE_URL=
APP_DEEP_LINK_SCHEME=cheevo

# Broadcasts
BROADCASTS_FROM_ADDRESS=events@cheevo.vip

# Integrations
# GIPHY_API_KEY=
# GOOGLE_PLACES_API_KEY=

SYSTEM_CONFIG_CACHE_TTL_SECONDS=60

# App links (.well-known)
# APPLE_TEAM_ID=
IOS_BUNDLE_ID=events.cheevo.app
ANDROID_PACKAGE_NAME=events.cheevo.app
# ANDROID_SHA256_FINGERPRINTS=
