model TicketTransfer {
  id             String   @id @db.Char(26)
  issuedTicketId String   @map("issued_ticket_id") @db.Char(26)
  eventId        String   @map("event_id") @db.Char(26)
  fromUserId     String   @map("from_user_id") @db.Char(26)
  toUserId       String   @map("to_user_id") @db.Char(26)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  issuedTicket IssuedTicket @relation(fields: [issuedTicketId], references: [id], onDelete: Cascade)

  @@index([issuedTicketId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("ticket_transfers")
}
