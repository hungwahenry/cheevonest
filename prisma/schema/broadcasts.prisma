enum BroadcastStatus {
  queued
  sending
  sent
  failed
  cancelled
}

enum BroadcastAudience {
  ticket_holders
  rsvpers
  both
}

enum SuppressionReason {
  unsubscribed
  bounced
  complained
}

model Broadcast {
  id              String            @id @db.Char(26)
  organisationId  String            @map("organisation_id") @db.Char(26)
  eventId         String            @map("event_id") @db.Char(26)
  createdByUserId String            @map("created_by_user_id") @db.Char(26)
  audience        BroadcastAudience
  subject         String            @db.VarChar(120)
  bodyHtml        String            @map("body_html")
  bodyText        String            @map("body_text")
  recipientsCount Int               @default(0) @map("recipients_count")
  sentCount       Int               @default(0) @map("sent_count")
  failedCount     Int               @default(0) @map("failed_count")
  status          BroadcastStatus   @default(queued)
  failureReason   String?           @map("failure_reason")
  sentAt          DateTime?         @map("sent_at") @db.Timestamptz(6)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdByUserId], references: [id])

  @@index([organisationId, createdAt])
  @@index([eventId, createdAt])
  @@map("broadcasts")
}

model BroadcastSuppression {
  id             String            @id @db.Char(26)
  email          String
  organisationId String?           @map("organisation_id") @db.Char(26)
  reason         SuppressionReason
  userId         String?           @map("user_id") @db.Char(26)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  organisation Organisation? @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([email, organisationId])
  @@index([email])
  @@map("broadcast_suppressions")
}
