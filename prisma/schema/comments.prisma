model EventComment {
  id           String   @id @db.Char(26)
  eventId      String   @map("event_id") @db.Char(26)
  userId       String   @map("user_id") @db.Char(26)
  parentId     String?  @map("parent_id") @db.Char(26)
  body         String?
  gif          Json?
  mentions     Json?
  likesCount   Int      @default(0) @map("likes_count")
  repliesCount Int      @default(0) @map("replies_count")
  flagsCount   Int      @default(0) @map("flags_count")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  event   Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  EventComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies EventComment[]     @relation("CommentReplies")
  likes   EventCommentLike[]
  flags   EventCommentFlag[]

  @@index([eventId, parentId, createdAt])
  @@index([parentId, createdAt])
  @@map("event_comments")
}

model EventCommentLike {
  commentId String   @map("comment_id") @db.Char(26)
  userId    String   @map("user_id") @db.Char(26)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  comment EventComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
  @@map("event_comment_likes")
}

model EventCommentFlag {
  commentId       String   @map("comment_id") @db.Char(26)
  flaggedByUserId String   @map("flagged_by_user_id") @db.Char(26)
  reason          String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  comment   EventComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  flaggedBy User         @relation(fields: [flaggedByUserId], references: [id], onDelete: Cascade)

  @@id([commentId, flaggedByUserId])
  @@index([flaggedByUserId])
  @@map("event_comment_flags")
}

enum ReportStatus {
  open
  under_review
  actioned
  dismissed
}

model ReportReason {
  id              String   @id @db.Char(26)
  slug            String   @unique @db.VarChar(64)
  label           String
  description     String?
  scopeTypes      Json     @default("[]") @map("scope_types")
  displayOrder    Int      @default(0) @map("display_order") @db.SmallInt
  requiresDetails Boolean  @default(false) @map("requires_details")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  reports Report[]

  @@index([isActive, displayOrder])
  @@map("report_reasons")
}

model Report {
  id               String       @id @db.Char(26)
  targetType       String       @map("target_type") @db.VarChar(64)
  targetId         String       @map("target_id") @db.Char(26)
  reporterUserId   String       @map("reporter_user_id") @db.Char(26)
  reportReasonId   String       @map("report_reason_id") @db.Char(26)
  details          String?
  status           ReportStatus @default(open)
  reviewedByUserId String?      @map("reviewed_by_user_id") @db.Char(26)
  reviewedAt       DateTime?    @map("reviewed_at") @db.Timestamptz(6)
  resolutionNote   String?      @map("resolution_note")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  reporter   User         @relation("ReportsFiled", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reason     ReportReason @relation(fields: [reportReasonId], references: [id], onDelete: Restrict)
  reviewedBy User?        @relation("ReportsReviewed", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([reporterUserId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([status])
  @@index([reporterUserId])
  @@map("reports")
}
