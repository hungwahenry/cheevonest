enum OrderStatus {
  pending
  paid
  cancelled
  refunded
}

enum IssuedTicketStatus {
  valid
  scanned
  revoked
}

enum PaymentStatus {
  pending
  successful
  failed
  abandoned
  refunded
}

model Order {
  id                 String      @id @db.Char(26)
  userId             String      @map("user_id") @db.Char(26)
  eventId            String      @map("event_id") @db.Char(26)
  paymentId          String?     @map("payment_id") @db.Char(26)
  status             OrderStatus @default(pending)
  subtotalMinor      BigInt      @map("subtotal_minor")
  feesMinor          BigInt      @map("fees_minor")
  totalMinor         BigInt      @map("total_minor")
  itemsQuantityTotal Int         @default(0) @map("items_quantity_total")
  currency           Currency    @default(NGN)
  accessToken        String?     @unique @map("access_token") @db.VarChar(64)
  paidAt             DateTime?   @map("paid_at") @db.Timestamptz(6)
  cancelledAt        DateTime?   @map("cancelled_at") @db.Timestamptz(6)
  refundedAt         DateTime?   @map("refunded_at") @db.Timestamptz(6)
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  payment       Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  holds         TicketHold[]
  issuedTickets IssuedTicket[]

  @@index([userId, createdAt])
  @@index([eventId, status])
  @@map("orders")
}

model OrderItem {
  id             String   @id @db.Char(26)
  orderId        String   @map("order_id") @db.Char(26)
  eventTicketId  String   @map("event_ticket_id") @db.Char(26)
  quantity       Int
  unitPriceMinor BigInt   @map("unit_price_minor")
  subtotalMinor  BigInt   @map("subtotal_minor")
  ticketName     String   @map("ticket_name") @db.VarChar(60)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticket        EventTicket    @relation(fields: [eventTicketId], references: [id], onDelete: Restrict)
  issuedTickets IssuedTicket[]

  @@index([orderId])
  @@map("order_items")
}

model TicketHold {
  id            String   @id @db.Char(26)
  eventTicketId String   @map("event_ticket_id") @db.Char(26)
  orderId       String   @map("order_id") @db.Char(26)
  quantity      Int
  expiresAt     DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  ticket EventTicket @relation(fields: [eventTicketId], references: [id], onDelete: Cascade)
  order  Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([eventTicketId, expiresAt])
  @@index([orderId])
  @@map("ticket_holds")
}

model IssuedTicket {
  id              String             @id @db.Char(26)
  orderId         String             @map("order_id") @db.Char(26)
  orderItemId     String             @map("order_item_id") @db.Char(26)
  eventId         String             @map("event_id") @db.Char(26)
  eventTicketId   String             @map("event_ticket_id") @db.Char(26)
  holderUserId    String             @map("holder_user_id") @db.Char(26)
  code            String             @unique @db.VarChar(32)
  status          IssuedTicketStatus @default(valid)
  scannedAt       DateTime?          @map("scanned_at") @db.Timestamptz(6)
  scannedByUserId String?            @map("scanned_by_user_id") @db.Char(26)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticket    EventTicket @relation(fields: [eventTicketId], references: [id], onDelete: Restrict)
  holder    User        @relation("HeldTickets", fields: [holderUserId], references: [id], onDelete: Cascade)
  scannedBy User?       @relation("ScannedTickets", fields: [scannedByUserId], references: [id], onDelete: SetNull)
  transfers TicketTransfer[]

  @@index([eventId, status])
  @@index([holderUserId])
  @@map("issued_tickets")
}

model Payment {
  id                String        @id @db.Char(26)
  userId            String        @map("user_id") @db.Char(26)
  provider          String        @db.VarChar(32)
  reference         String        @unique @db.VarChar(64)
  providerReference String?       @map("provider_reference") @db.VarChar(128)
  amountMinor       BigInt        @map("amount_minor")
  currency          Currency      @default(NGN)
  status            PaymentStatus @default(pending)
  purposableType    String?       @map("purposable_type") @db.VarChar(64)
  purposableId      String?       @map("purposable_id") @db.Char(26)
  metadata          Json?
  providerResponse  Json?         @map("provider_response")
  authorizedAt      DateTime?     @map("authorized_at") @db.Timestamptz(6)
  failedAt          DateTime?     @map("failed_at") @db.Timestamptz(6)
  refundedAt        DateTime?     @map("refunded_at") @db.Timestamptz(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([provider, providerReference])
  @@index([purposableType, purposableId])
  @@index([userId, createdAt])
  @@map("payments")
}

model WebhookEvent {
  id         BigInt   @id @default(autoincrement())
  provider   String   @db.VarChar(32)
  eventType  String   @map("event_type") @db.VarChar(64)
  externalId String   @map("external_id") @db.VarChar(128)
  receivedAt DateTime @map("received_at") @db.Timestamptz(6)
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([provider, eventType, externalId])
  @@index([receivedAt])
  @@map("webhook_events")
}
