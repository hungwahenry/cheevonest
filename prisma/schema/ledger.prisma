enum LedgerEntryType {
  sale
  refund
  adjustment
}

model LedgerEntry {
  id             String          @id @db.Char(26)
  organisationId String          @map("organisation_id") @db.Char(26)
  type           LedgerEntryType
  amountMinor    BigInt          @map("amount_minor")
  currency       Currency        @default(NGN)
  sourceType     String          @map("source_type") @db.VarChar(32)
  sourceId       String          @map("source_id") @db.Char(26)
  availableAt    DateTime        @map("available_at") @db.Timestamptz(6)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@index([organisationId, availableAt])
  @@index([sourceType, sourceId])
  @@map("ledger_entries")
}
