model Subscription {
  userId         String   @map("user_id") @db.Char(26)
  organisationId String   @map("organisation_id") @db.Char(26)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@id([userId, organisationId])
  @@index([organisationId])
  @@map("subscriptions")
}

model EventRsvp {
  userId    String   @map("user_id") @db.Char(26)
  eventId   String   @map("event_id") @db.Char(26)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
  @@index([eventId])
  @@map("event_rsvps")
}

model Block {
  blockerUserId String   @map("blocker_user_id") @db.Char(26)
  blockableType String   @map("blockable_type") @db.VarChar(32)
  blockableId   String   @map("blockable_id") @db.Char(26)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  blocker User @relation(fields: [blockerUserId], references: [id], onDelete: Cascade)

  @@id([blockerUserId, blockableType, blockableId])
  @@index([blockableType, blockableId])
  @@map("blocks")
}

model SearchIndex {
  searchableType String                   @map("searchable_type") @db.VarChar(64)
  searchableId   String                   @map("searchable_id") @db.Char(26)
  fts            Unsupported("tsvector")?
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([searchableType, searchableId])
  @@index([fts], type: Gin)
  @@map("search_index")
}
